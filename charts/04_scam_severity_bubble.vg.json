{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 420,
  "data": {
    "url": "data/vega_lite_ready/scamwatch_scam_type_summary.csv"
  },
  "mark": {
    "type": "circle",
    "opacity": 0.75,
    "stroke": "white",
    "strokeWidth": 1.5
  },
  "encoding": {
    "x": {
      "field": "reports",
      "type": "quantitative",
      "title": "Reports",
      "scale": {
        "type": "sqrt"
      },
      "axis": {
        "format": "~s"
      }
    },
    "y": {
      "field": "amount_lost",
      "type": "quantitative",
      "title": "Amount lost ($)",
      "scale": {
        "type": "sqrt"
      },
      "axis": {
        "format": "$~s"
      }
    },
    "size": {
      "field": "average_loss_per_report",
      "type": "quantitative",
      "title": "Average loss per report",
      "scale": {
        "range": [80, 1700]
      },
      "legend": {
        "format": "$~s"
      }
    },
    "color": {
      "field": "primary_scam_category",
      "type": "nominal",
      "title": "Scam category"
    },
    "tooltip": [
      {
        "field": "scam_type",
        "type": "nominal",
        "title": "Scam type"
      },
      {
        "field": "primary_scam_category",
        "type": "nominal",
        "title": "Category"
      },
      {
        "field": "reports",
        "type": "quantitative",
        "title": "Reports",
        "format": ","
      },
      {
        "field": "amount_lost",
        "type": "quantitative",
        "title": "Amount lost",
        "format": "$,.0f"
      },
      {
        "field": "average_loss_per_report",
        "type": "quantitative",
        "title": "Average loss per report",
        "format": "$,.0f"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "gridColor": "#eeeeee"
    },
    "legend": {
      "orient": "bottom"
    }
  }
}