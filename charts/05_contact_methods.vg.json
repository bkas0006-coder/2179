{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "width": "container",
  "height": 390,
  "data": {
    "url": "data/vega_lite_ready/scamwatch_contact_method_by_category.csv"
  },
  "transform": [
    {
      "filter": "datum.contact_method != 'unspecified' && datum.contact_method != 'Unspecified'"
    }
  ],
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "y": {
      "field": "contact_method",
      "type": "nominal",
      "title": null,
      "sort": "-x"
    },
    "x": {
      "field": "amount_lost",
      "type": "quantitative",
      "stack": "normalize",
      "title": "Share of losses",
      "axis": {
        "format": "%"
      }
    },
    "color": {
      "field": "scam_category",
      "type": "nominal",
      "title": "Scam category",
      "legend": {
        "orient": "bottom",
        "columns": 2,
        "labelLimit": 160
      }
    },
    "tooltip": [
      {
        "field": "contact_method",
        "type": "nominal",
        "title": "Contact method"
      },
      {
        "field": "scam_category",
        "type": "nominal",
        "title": "Category"
      },
      {
        "field": "amount_lost",
        "type": "quantitative",
        "title": "Amount lost",
        "format": "$,.0f"
      },
      {
        "field": "reports",
        "type": "quantitative",
        "title": "Reports",
        "format": ","
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "gridColor": "#eeeeee",
      "labelColor": "#333333",
      "titleColor": "#111111"
    }
  }
}