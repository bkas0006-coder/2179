{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "width": "container",
  "height": 390,
  "data": {
    "url": "data/vega_lite_ready/personal_fraud_scam_age_group_2024_25.csv"
  },
  "transform": [
    {
      "filter": "datum.category != null && datum.victimisation_rate_percent != null"
    },
    {
      "calculate": "format(datum.victimisation_rate_percent, '.1f') + '%'",
      "as": "rate_label"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "height": 3,
        "color": "#d2d2d7"
      },
      "encoding": {
        "y": {
          "field": "category",
          "type": "nominal",
          "sort": "-x",
          "title": "Age group",
          "axis": {
            "labelLimit": 160
          }
        },
        "x": {
          "field": "victimisation_rate_percent",
          "type": "quantitative",
          "title": "Scam victimisation rate (%)"
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 150,
        "color": "#0071e3",
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "y": {
          "field": "category",
          "type": "nominal",
          "sort": "-x",
          "title": "Age group",
          "axis": {
            "labelLimit": 160
          }
        },
        "x": {
          "field": "victimisation_rate_percent",
          "type": "quantitative",
          "title": "Scam victimisation rate (%)"
        },
        "tooltip": [
          {
            "field": "category",
            "type": "nominal",
            "title": "Age group"
          },
          {
            "field": "experienced_scam_000",
            "type": "quantitative",
            "title": "Experienced scam ('000)",
            "format": ",.1f"
          },
          {
            "field": "total_persons_000",
            "type": "quantitative",
            "title": "Total persons ('000)",
            "format": ",.1f"
          },
          {
            "field": "victimisation_rate_percent",
            "type": "quantitative",
            "title": "Victimisation rate",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 11,
        "color": "#333333"
      },
      "encoding": {
        "y": {
          "field": "category",
          "type": "nominal",
          "sort": "-x"
        },
        "x": {
          "field": "victimisation_rate_percent",
          "type": "quantitative"
        },
        "text": {
          "field": "rate_label",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "gridColor": "#eeeeee",
      "labelColor": "#333333",
      "titleColor": "#111111"
    }
  }
}