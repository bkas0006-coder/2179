{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 360,
  "data": {
    "url": "data/vega_lite_ready/personal_fraud_scam_age_group_2024_25.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 2,
        "color": "#d2d2d7"
      },
      "encoding": {
        "y": {
          "field": "category",
          "type": "nominal",
          "sort": {
            "field": "victimisation_rate_percent",
            "order": "descending"
          },
          "title": "Age group"
        },
        "x": {
          "field": "victimisation_rate_percent",
          "type": "quantitative",
          "title": "Scam victimisation rate (%)"
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 160,
        "color": "#0071e3"
      },
      "encoding": {
        "y": {
          "field": "category",
          "type": "nominal",
          "sort": {
            "field": "victimisation_rate_percent",
            "order": "descending"
          },
          "title": "Age group"
        },
        "x": {
          "field": "victimisation_rate_percent",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "category",
            "type": "nominal",
            "title": "Age group"
          },
          {
            "field": "experienced_scam_000",
            "type": "quantitative",
            "title": "Experienced scam ('000)",
            "format": ",.1f"
          },
          {
            "field": "total_persons_000",
            "type": "quantitative",
            "title": "Total persons ('000)",
            "format": ",.1f"
          },
          {
            "field": "victimisation_rate_percent",
            "type": "quantitative",
            "title": "Victimisation rate",
            "format": ".1f"
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "gridColor": "#eeeeee"
    }
  }
}