{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "data": {
    "url": "data/vega_lite_ready/scamwatch_monthly.csv"
  },
  "transform": [
    {
      "calculate": "datum.month_label == 'Jan 2025' ? 1 : datum.month_label == 'Feb 2025' ? 2 : datum.month_label == 'Mar 2025' ? 3 : datum.month_label == 'Apr 2025' ? 4 : datum.month_label == 'May 2025' ? 5 : datum.month_label == 'Jun 2025' ? 6 : datum.month_label == 'Jul 2025' ? 7 : datum.month_label == 'Aug 2025' ? 8 : datum.month_label == 'Sep 2025' ? 9 : datum.month_label == 'Oct 2025' ? 10 : datum.month_label == 'Nov 2025' ? 11 : datum.month_label == 'Dec 2025' ? 12 : 99",
      "as": "month_order"
    }
  ],
  "vconcat": [
    {
      "width": "container",
      "height": 250,
      "layer": [
        {
          "mark": {
            "type": "area",
            "line": true,
            "point": true,
            "interpolate": "monotone",
            "opacity": 0.35,
            "color": "#0071e3"
          },
          "encoding": {
            "x": {
              "field": "month_label",
              "type": "ordinal",
              "sort": {
                "field": "month_order",
                "order": "ascending"
              },
              "title": null,
              "axis": {
                "labelAngle": 0
              }
            },
            "y": {
              "field": "amount_lost",
              "type": "quantitative",
              "title": "Amount lost ($)",
              "axis": {
                "format": "$~s"
              }
            },
            "tooltip": [
              {
                "field": "month_label",
                "type": "nominal",
                "title": "Month"
              },
              {
                "field": "amount_lost",
                "type": "quantitative",
                "title": "Amount lost",
                "format": "$,.0f"
              },
              {
                "field": "reports",
                "type": "quantitative",
                "title": "Reports",
                "format": ","
              },
              {
                "field": "average_loss_per_report",
                "type": "quantitative",
                "title": "Average loss per report",
                "format": "$,.0f"
              }
            ]
          }
        },
        {
          "transform": [
            {
              "window": [
                {
                  "op": "rank",
                  "as": "loss_rank"
                }
              ],
              "sort": [
                {
                  "field": "amount_lost",
                  "order": "descending"
                }
              ]
            },
            {
              "filter": "datum.loss_rank == 1"
            },
            {
              "calculate": "'Peak loss: $' + format(datum.amount_lost / 1000000, '.1f') + 'M'",
              "as": "annotation"
            }
          ],
          "mark": {
            "type": "text",
            "align": "left",
            "baseline": "bottom",
            "dx": 8,
            "dy": -8,
            "fontSize": 12,
            "fontWeight": "bold",
            "color": "#1d1d1f"
          },
          "encoding": {
            "x": {
              "field": "month_label",
              "type": "ordinal",
              "sort": {
                "field": "month_order",
                "order": "ascending"
              }
            },
            "y": {
              "field": "amount_lost",
              "type": "quantitative"
            },
            "text": {
              "field": "annotation",
              "type": "nominal"
            }
          }
        }
      ]
    },
    {
      "width": "container",
      "height": 95,
      "mark": {
        "type": "bar",
        "color": "#8e8e93"
      },
      "encoding": {
        "x": {
          "field": "month_label",
          "type": "ordinal",
          "sort": {
            "field": "month_order",
            "order": "ascending"
          },
          "title": "Month",
          "axis": {
            "labelAngle": 0
          }
        },
        "y": {
          "field": "reports",
          "type": "quantitative",
          "title": "Reports",
          "axis": {
            "format": "~s"
          }
        },
        "tooltip": [
          {
            "field": "month_label",
            "type": "nominal",
            "title": "Month"
          },
          {
            "field": "reports",
            "type": "quantitative",
            "title": "Reports",
            "format": ","
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "gridColor": "#eeeeee",
      "labelColor": "#555555",
      "titleColor": "#111111"
    }
  }
}