{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "data": {
    "url": "data/vega_lite_ready/scamwatch_monthly.csv"
  },
  "vconcat": [
    {
      "width": "container",
      "height": 230,
      "mark": {
        "type": "area",
        "line": true,
        "point": true,
        "interpolate": "monotone",
        "opacity": 0.35,
        "color": "#4d6fa9"
      },
      "encoding": {
        "x": {
          "field": "month_label",
          "type": "ordinal",
          "sort": {
            "field": "month",
            "order": "ascending"
          },
          "title": null,
          "axis": {
            "labelAngle": 0
          }
        },
        "y": {
          "field": "amount_lost",
          "type": "quantitative",
          "title": "Amount lost ($)",
          "axis": {
            "format": "$~s"
          }
        },
        "tooltip": [
          {
            "field": "month_label",
            "type": "nominal",
            "title": "Month"
          },
          {
            "field": "amount_lost",
            "type": "quantitative",
            "title": "Amount lost",
            "format": "$,.0f"
          },
          {
            "field": "reports",
            "type": "quantitative",
            "title": "Reports",
            "format": ","
          }
        ]
      }
    },
    {
      "width": "container",
      "height": 95,
      "mark": {
        "type": "bar",
        "color": "#888888"
      },
      "encoding": {
        "x": {
          "field": "month_label",
          "type": "ordinal",
          "sort": {
            "field": "month",
            "order": "ascending"
          },
          "title": "Month",
          "axis": {
            "labelAngle": 0
          }
        },
        "y": {
          "field": "reports",
          "type": "quantitative",
          "title": "Reports",
          "axis": {
            "format": "~s"
          }
        },
        "tooltip": [
          {
            "field": "month_label",
            "type": "nominal",
            "title": "Month"
          },
          {
            "field": "reports",
            "type": "quantitative",
            "title": "Reports",
            "format": ","
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "gridColor": "#eeeeee",
      "labelColor": "#555555",
      "titleColor": "#222222"
    }
  }
}