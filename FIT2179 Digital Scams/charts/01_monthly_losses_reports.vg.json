{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "url": "data/vega_lite_ready/scamwatch_monthly.csv"
  },
  "vconcat": [
    {
      "width": "container",
      "height": 230,
      "mark": {
        "type": "area",
        "line": true,
        "point": true,
        "interpolate": "monotone",
        "opacity": 0.35,
        "color": "#0071e3"
      },
      "encoding": {
        "x": {
          "field": "month",
          "type": "temporal",
          "title": null,
          "axis": {
            "format": "%b",
            "labelAngle": 0
          }
        },
        "y": {
          "field": "amount_lost",
          "type": "quantitative",
          "title": "Amount lost ($)",
          "axis": {
            "format": "$~s"
          }
        },
        "tooltip": [
          {
            "field": "month_label",
            "type": "nominal",
            "title": "Month"
          },
          {
            "field": "amount_lost",
            "type": "quantitative",
            "title": "Amount lost",
            "format": "$,.0f"
          },
          {
            "field": "reports",
            "type": "quantitative",
            "title": "Reports",
            "format": ","
          },
          {
            "field": "average_loss_per_report",
            "type": "quantitative",
            "title": "Average loss per report",
            "format": "$,.0f"
          }
        ]
      }
    },
    {
      "width": "container",
      "height": 100,
      "mark": {
        "type": "bar",
        "cornerRadiusTopLeft": 4,
        "cornerRadiusTopRight": 4,
        "color": "#86868b"
      },
      "encoding": {
        "x": {
          "field": "month",
          "type": "temporal",
          "title": "Month",
          "axis": {
            "format": "%b %Y",
            "labelAngle": 0
          }
        },
        "y": {
          "field": "reports",
          "type": "quantitative",
          "title": "Reports",
          "axis": {
            "format": "~s"
          }
        },
        "tooltip": [
          {
            "field": "month_label",
            "type": "nominal",
            "title": "Month"
          },
          {
            "field": "reports",
            "type": "quantitative",
            "title": "Reports",
            "format": ","
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "gridColor": "#eeeeee",
      "labelColor": "#6e6e73",
      "titleColor": "#6e6e73"
    }
  }
}