{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 380,
  "data": {
    "url": "data/vega_lite_ready/aic_harms_individual_core_2024.csv"
  },
  "mark": {
    "type": "rect",
    "cornerRadius": 3
  },
  "encoding": {
    "x": {
      "field": "harm_type",
      "type": "nominal",
      "title": null,
      "axis": {
        "labelAngle": -25
      }
    },
    "y": {
      "field": "cybercrime_type",
      "type": "nominal",
      "title": null,
      "axis": {
        "labelLimit": 165
      }
    },
    "color": {
      "field": "percent_2024",
      "type": "quantitative",
      "title": "Affected (%)",
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "cybercrime_type",
        "type": "nominal",
        "title": "Cybercrime type"
      },
      {
        "field": "harm_type",
        "type": "nominal",
        "title": "Harm type"
      },
      {
        "field": "percent_2024",
        "type": "quantitative",
        "title": "2024",
        "format": ".1f"
      },
      {
        "field": "percent_2023",
        "type": "quantitative",
        "title": "2023",
        "format": ".1f"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "grid": false
    }
  }
}