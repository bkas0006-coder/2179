{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 420,
  "data": {
    "url": "data/vega_lite_ready/scamwatch_top_scam_types_by_reports_top15.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 5,
    "color": "#1d1d1f"
  },
  "encoding": {
    "y": {
      "field": "scam_type",
      "type": "nominal",
      "sort": "-x",
      "title": null,
      "axis": {
        "labelLimit": 185
      }
    },
    "x": {
      "field": "reports",
      "type": "quantitative",
      "title": "Number of reports",
      "axis": {
        "format": "~s"
      }
    },
    "tooltip": [
      {
        "field": "scam_type",
        "type": "nominal",
        "title": "Scam type"
      },
      {
        "field": "reports",
        "type": "quantitative",
        "title": "Reports",
        "format": ","
      },
      {
        "field": "amount_lost",
        "type": "quantitative",
        "title": "Amount lost",
        "format": "$,.0f"
      },
      {
        "field": "average_loss_per_report",
        "type": "quantitative",
        "title": "Average loss per report",
        "format": "$,.0f"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "gridColor": "#eeeeee"
    }
  }
}